    "reelHtml": "<!DOCTYPE html><html lang=\"ja\"><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=1080,height=1920\"><title>ChatGPTに糖尿病を診断させた</title><link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700;900&display=swap\" rel=\"stylesheet\"><script src=\"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js\"></script><style>*{margin:0;padding:0;box-sizing:border-box}body{width:1080px;height:1920px;overflow:hidden;font-family:'Noto Sans JP',sans-serif}.comp{position:relative;width:1080px;height:1920px;background:linear-gradient(180deg,#0f172a 0%,#1e293b 50%,#1e1b4b 100%);overflow:hidden}.scene{position:absolute;top:0;left:0;width:100%;height:100%;display:flex;flex-direction:column;justify-content:center;align-items:center;padding:60px;opacity:0;text-align:center}.watermark-wrap{position:absolute;right:20px;bottom:120px;z-index:10;pointer-events:none;text-align:center;display:flex;flex-direction:column;align-items:center}.watermark-wrap img{height:400px;width:auto;object-fit:contain;filter:drop-shadow(0 4px 16px rgba(0,0,0,.4))}.watermark-name{font-size:24px;font-weight:700;color:#fff;margin-top:8px;text-shadow:0 2px 8px rgba(0,0,0,.5)}.hook-tag{background:rgba(129,140,248,.2);border:1px solid #818cf8;color:#a5b4fc;font-size:28px;font-weight:700;padding:10px 28px;border-radius:30px;margin-bottom:30px}.hook-title{font-size:88px;font-weight:900;color:#fff;line-height:1.2;word-break:keep-all;text-shadow:0 4px 20px rgba(0,0,0,.5)}.hook-accent{color:#818cf8}.hook-sub{font-size:36px;color:rgba(255,255,255,.8);margin-top:30px;line-height:1.6}.score-section{width:100%}.score-title{font-size:40px;font-weight:700;color:#fff;margin-bottom:30px;text-align:center}.score-card{background:rgba(255,255,255,.07);border-radius:20px;padding:22px 30px;margin-bottom:14px;display:flex;align-items:center;justify-content:space-between;opacity:0;transform:translateX(-60px)}.score-card.high{border-left:5px solid #34d399}.score-card.mid{b