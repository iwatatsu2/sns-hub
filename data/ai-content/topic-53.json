    "reelHtml": "<!DOCTYPE html><html lang=\"ja\"><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=1080,height=1920\"><title>CGMつけてサウナに入ったら血糖値が激変した</title><link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700;900&display=swap\" rel=\"stylesheet\"><script src=\"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js\"></script><style>*{margin:0;padding:0;box-sizing:border-box}body{width:1080px;height:1920px;overflow:hidden;font-family:'Noto Sans JP',sans-serif}.comp{position:relative;width:1080px;height:1920px;background:linear-gradient(180deg,#0d1b2a 0%,#1a2f3f 50%,#0d3347 100%);overflow:hidden}.scene{position:absolute;top:0;left:0;width:100%;height:100%;display:flex;flex-direction:column;justify-content:center;align-items:center;padding:70px;opacity:0;text-align:center}.watermark-wrap{position:absolute;right:24px;bottom:130px;z-index:10;pointer-events:none;text-align:center;display:flex;flex-direction:column;align-items:center}.watermark-wrap img{height:380px;width:auto;object-fit:contain;filter:drop-shadow(0 4px 16px rgba(0,0,0,.5))}.watermark-name{font-size:24px;font-weight:700;color:#fff;margin-top:8px;text-shadow:0 2px 8px rgba(0,0,0,.5)}.hook-badge{display:inline-block;background:rgba(251,146,60,.2);border:2px solid #fb923c;color:#fb923c;font-size:30px;font-weight:700;padding:10px 28px;border-radius:30px;margin-bottom:28px;opacity:0}.hook-main{font-size:84px;font-weight:900;color:#fff;line-height:1.2;word-break:keep-all;text-shadow:0 4px 24px rgba(0,0,0,.6);opacity:0}.hook-accent{color:#fb923c}.hook-sub{font-size:34px;color:rgba(255,255,255,.75);margin-top:28px;line-height:1.6;opacity:0}.data-section{width:100%;max-width:940px}.data-title{font-size:44px;font-weight:700;color:#fff;margin-bottom:36px}.data-split{display:flex;gap:24px;margin-bottom:30px}.data-box{flex:1;border-radius:20px;padding:36px 28px;text-align:center}.data-box.before{background:rgba(251,146,60,.1);border:2px solid rgba(251,146,60,.3)}.d