    "reelHtml": "<!DOCTYPE html><html lang=\"ja\"><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=1080,height=1920\"><title>医師がClaude Codeで医療アプリを作ってみた</title><link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700;900&display=swap\" rel=\"stylesheet\"><script src=\"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js\"></script><style>*{margin:0;padding:0;box-sizing:border-box}body{width:1080px;height:1920px;overflow:hidden;font-family:'Noto Sans JP',sans-serif}.comp{position:relative;width:1080px;height:1920px;background:linear-gradient(180deg,#0a0f1a 0%,#0f172a 50%,#1e1040 100%);overflow:hidden}.scene{position:absolute;top:0;left:0;width:100%;height:100%;display:flex;flex-direction:column;justify-content:center;align-items:center;padding:80px;opacity:0;text-align:center}.watermark-wrap{position:absolute;right:20px;bottom:120px;z-index:10;pointer-events:none;text-align:center;display:flex;flex-direction:column;align-items:center}.watermark-wrap img{height:360px;width:auto;object-fit:contain;filter:drop-shadow(0 4px 16px rgba(0,0,0,.4))}.watermark-name{font-size:24px;font-weight:700;color:#fff;margin-top:8px;text-shadow:0 2px 8px rgba(0,0,0,.5)}.hook-main{font-size:86px;font-weight:900;color:#fff;line-height:1.15;word-break:keep-all;text-shadow:0 4px 20px rgba(0,0,0,.5)}.hook-accent{color:#818cf8}.hook-sub{font-size:40px;font-weight:700;color:rgba(255,255,255,.8);margin-top:28px;line-height:1.5;background:rgba(129,140,248,.12);border:2px solid rgba(129,140,248,.35);border-radius:20px;padding:18px 28px}.app-grid{width:100%;max-width:940px}.app-card{background:rgba(255,255,255,.06);border:2px solid rgba(129,140,248,.25);border-radius:24px;padding:34px 40px;margin-bottom:22px;display:flex;align-items:center;gap:28px;opacity:0;transform:translateX(-60px)}.app-icon{font-size:54px;flex-shrink:0}.app-info{text-align:left;flex:1}.app-name{font-size:40px;font-weight:900;color:#818cf8;margin-bottom:6px}.app-desc{font-size:30px;color:rgba(255,255,255,.75);line-height:1.4}.app-badge{font-size:26px;background:rgba(129,140,248,.15);color:#a5b4fc;padding:6px 16px;border-radius:20px;white-space:nowrap}.code-box{background:rgba(15,20,30,.8);border:2px solid rgba(129,140,248,.3);border-radius:24px;padding:50px;max-width:920px;width:100%;text-align:left}.code-comment{font-size:28px;color:rgba(129,140,248,.6);margin-bottom:16px}.code-line{font-size:32px;color:#a5f3a0;font-family:monospace;line-height:1.7}.code-highlight{color:#818cf8;font-weight:700}.no-code-msg{font-size:44px;font-weight:700;color:#fff;text-align:center;margin-top:30px;padding:24px;background:rgba(129,140,248,.1);border-radius:16px;border:2px solid rgba(129,140,248,.3)}.insight-box{background:rgba(129,140,248,.08);border:2px solid rgba(129,140,248,.3);border-radius:28px;padding:50px;max-width:920px;width:100%}.insight-title{font-size:44px;font-weight:700;color:#818cf8;margin-bottom:28px}.insight-vs{display:flex;gap:20px;margin-bottom:28px}.vs-col{flex:1;border-radius:16px;padding:24px;text-align:center}.vs-col.old{background:rgba(239,68,68,.08);border:2px solid rgba(239,68,68,.25)}.vs-col.new{background:rgba(129,140,248,.08);border:2px solid rgba(129,140,248,.25)}.vs-label{font-size:26px;color:rgba(255,255,255,.5);margin-bottom:10px}.vs-text{font-size:34px;font-weight:700}.vs-col.old .vs-text{color:#ef4444}.vs-col.new .vs-text{color:#818cf8}.insight-msg{font-size:36px;font-weight:700;color:#fff;line-height:1.5;text-align:center}.follow-section{text-align:center}.follow-avatar{width:240px;height:auto;object-fit:contain;filter:drop-shadow(0 8px 30px rgba(0,0,0,.5));margin-bottom:20px}.follow-name{font-size:56px;font-weight:900;color:#fff;margin-bottom:10px}.follow-title{font-size:28px;color:rgba(255,255,255,.65);margin-bottom:30px}.follow-btn{display:inline-block;background:linear-gradient(135deg,#6366f1,#818cf8);color:#fff;font-size:44px;font-weight:700;padding:22px 60px;border-radius:50px;box-shadow:0 8px 30px rgba(99,102,241,.4)}.follow-actions{margin-top:24px;font-size:28px;color:rgba(255,255,255,.6)}</style></head><body><div class=\"comp\"><div class=\"watermark-wrap\" id=\"watermark\"><img src=\"https://sns-hub-five.vercel.app/dr-iwatatsu.png\" alt=\"Dr.いわたつ\"><div class=\"watermark-name\">Dr.いわたつ</div></div><div class=\"scene\" id=\"s1\"><div class=\"hook-main\"><span class=\"hook-accent\">プログラミング<br>未経験</span>の<br>医師が</div><div class=\"hook-sub\">AIだけで医療アプリを<br>3本リリースした話</div></div><div class=\"scene\" id=\"s2\"><div class=\"app-grid\"><div class=\"app-card\"><div class=\"app-icon\">💉</div><div class=\"app-info\"><div class=\"app-name\">InsuCalc</div><div class=\"app-desc\">インスリン計算ツール</div></div><div class=\"app-badge\">病棟で使用中</div></div><div class=\"app-card\"><div class=\"app-icon\">🧭</div><div class=\"app-info\"><div class=\"app-name\">DM Compass</div><div class=\"app-desc\">糖尿病病棟オールインワン</div></div><div class=\"app-badge\">研修医向け</div></div><div class=\"app-card\"><div class=\"app-icon\">📱</div><div class=\"app-info\"><div class=\"app-name\">T1Life</div><div class=\"app-desc\">1型糖尿病患者向けアプリ</div></div><div class=\"app-badge\">患者さんが使用</div></div></div></div><div class=\"scene\" id=\"s3\"><div class=\"code-box\"><div class=\"code-comment\">// 私が書いたコードの量</div><div class=\"code-line\"><span class=\"code-highlight\">const</span> myCode = <span class=\"code-highlight\">0</span>; <span style=\"color:rgba(255,255,255,.4)\">// 一行も書いていない</span></div><div class=\"code-line\"></div><div class=\"code-comment\">// 私がやったこと</div><div class=\"code-line\"><span class=\"code-highlight\">claudeCode</span>.tell(<span style=\"color:#fbbf24\">\"こういう機能が欲しい\"</span>);</div></div><div class=\"no-code-msg\">Claude Codeに日本語で伝えるだけ</div></div><div class=\"scene\" id=\"s4\"><div class=\"insight-box\"><div class=\"insight-title\">AI時代に必要なスキルとは</div><div class=\"insight-vs\"><div class=\"vs-col old\"><div class=\"vs-label\">必要でないもの</div><div class=\"vs-text\">コーディング<br>スキル</div></div><div style=\"display:flex;align-items:center;font-size:48px;color:rgba(255,255,255,.5)\">→</div><div class=\"vs-col new\"><div class=\"vs-label\">本当に必要なもの</div><div class=\"vs-text\">課題設定力</div></div></div><div class=\"insight-msg\">「何を作るか」を言語化できれば<br>実装はAIが代替する</div></div></div><div class=\"scene\" id=\"s5\"><div class=\"follow-section\"><img class=\"follow-avatar\" src=\"https://sns-hub-five.vercel.app/dr-iwatatsu.png\" alt=\"Dr.いわたつ\"><div class=\"follow-name\">Dr.いわたつ</div><div class=\"follow-title\">糖尿病専門医・指導医 / 内分泌専門医 / 医学博士</div><div class=\"follow-btn\">フォローする</div><div class=\"follow-actions\">💾 保存 &nbsp; 📤 シェア</div></div></div></div><script>const tl=gsap.timeline({repeat:-1});tl.to('#s1',{opacity:1,duration:.5},0).from('.hook-main',{scale:3,opacity:0,duration:.7,ease:'power4.out'},.2).from('.hook-sub',{y:40,opacity:0,duration:.6},.8).to('#s1',{opacity:0,duration:.4},3.5).to('#s2',{opacity:1,duration:.4},4).to('.app-card',{opacity:1,x:0,duration:.6,stagger:.6,ease:'power2.out'},4.5).to('#s2',{opacity:0,duration:.4},8.5).to('#s3',{opacity:1,duration:.4},9).from('.code-box',{y:40,opacity:0,duration:.7},9.3).from('.no-code-msg',{scale:.8,opacity:0,duration:.5},10.2).to('#s3',{opacity:0,duration:.4},12.5).to('#s4',{opacity:1,duration:.4},13).from('.insight-box',{y:50,opacity:0,duration:.7},13.3).to('#s4',{opacity:0,duration:.4},17.5).to('#watermark',{opacity:0,duration:.3},18).to('#s5',{opacity:1,duration:.5},18).from('.follow-avatar',{scale:.5,opacity:0,duration:.8,ease:'back.out(1.7)'},18.3).from('.follow-name',{y:20,opacity:0,duration:.5},18.8).from('.follow-btn',{scale:.8,opacity:0,duration:.5},19.2).to('#s5',{opacity:0,duration:.5},22.5);</script></body></html>"
