ter:drop-shadow(0 8px 30px rgba(0,0,0,.5));margin-bottom:20px}.follow-name{font-size:58px;font-weight:900;color:#fff;margin-bottom:10px}.follow-title{font-size:28px;color:rgba(255,255,255,.65);margin-bottom:30px}.follow-btn{display:inline-block;background:linear-gradient(135deg,#f59e0b,#fbbf24);color:#0f172a;font-size:44px;font-weight:700;padding:20px 60px;border-radius:50px}.follow-actions{margin-top:24px;font-size:28px;color:rgba(255,255,255,.55)}</style></head><body><div class=\"comp\"><div class=\"watermark-wrap\" id=\"watermark\"><img src=\"https://sns-hub-five.vercel.app/dr-iwatatsu.png\" alt=\"Dr.いわたつ\"><div class=\"watermark-name\">Dr.いわたつ</div></div><div class=\"scene\" id=\"s1\"><div class=\"hook-badge\">CGMデータで判定</div><div class=\"hook-title\">筋トレ</div><div class=\"vs-badge\">VS</div><div class=\"hook-title\">有酸素</div><div class=\"hook-sub\">血糖値に効くのは<br>どっちか、専門医が答える</div></div><div class=\"scene\" id=\"s2\"><div class=\"vs-wrap\"><div class=\"vs-side vs-left\"><div class=\"vs-label left\">筋トレ</div><div class=\"vs-item\"><div class=\"vs-item-label\">即時血糖低下</div><div class=\"vs-item-value low\">△ 一時的に上昇も</div></div><div class=\"vs-item\"><div class=\"vs-item-label\">HbA1c改善</div><div class=\"vs-item-value mid\">-0.57%</div></div><div class=\"vs-item\"><div class=\"vs-item-label\">効果持続</div><div class=\"vs-item-value good\">24〜48時間</div></div><div class=\"vs-item\"><div class=\"vs-item-label\">筋肉量増加</div><div class=\"vs-item-value good\">◎ 最強</div></div></div><div class=\"vs-center\"><div class=\"vs-center-badge\">VS</div></div><div class=\"vs-side vs-right\"><div class=\"vs-label right\">有酸素</div><div class=\"vs-item\"><div class=\"vs-item-label\">即時血糖低下</div><div class=\"vs-item-value good\">◎ 30〜50↓</div></div><div class=\"vs-item\"><div class=\"vs-item-label\">HbA1c改善</div><div class=\"vs-item-value good\">-0.73%</div></div><div class=\"vs-item\"><div class=\"vs-item-label\">効果持続</div><div class=\"vs-item-value mid\">数時間</div></div><div class=\"vs-item\"><div class=\"vs-item-label\">筋肉量増加</div><div class=\"vs-item-value low\">△ 限定的</div></div></div></div></div><div class=\"scene\" id=\"s3\"><div class=\"answer-box\"><div class=\"answer-label\">意外な答え</div><div class=\"answer-title\">「どちらか」<br>ではなく<br>組み合わせが最強</div><div class=\"answer-desc\">両方を組み合わせると<br>HbA1c改善効果が単独より<br><span style=\"color:#fbbf24;font-weight:900\">有意に高くなる</span><br>（複数RCTのメタアナリシス）</div></div></div><div class=\"scene\" id=\"s4\"><div class=\"plan-title\">週3回ジムの最強プラン</div><div class=\"plan-card\"><div class=\"plan-num\">①</div><div class=\"plan-text\">有酸素ウォームアップ<br><span style=\"font-size:26px;color:rgba(255,255,255,.6)\">軽いジョグ・バイク</span></div><div class=\"plan-time\">10分</div></div><div class=\"plan-card\"><div class=\"plan-num\">②</div><div class=\"plan-text\">筋トレ（大筋群）<br><span style=\"font-size:26px;color:rgba(255,255,255,.6)\">スクワット・ベンチ・ラット</span></div><div class=\"plan-time\">40分</div></div><div class=\"plan-card\"><div class=\"plan-num\">③</div><div class=\"plan-text\">有酸素フィニッシュ<br><span style=\"font-size:26px;color:rgba(255,255,255,.6)\">中強度・会話できる強度</span></div><div class=\"plan-time\">20分</div></div></div><div class=\"scene\" id=\"s5\"><div class=\"follow-section\"><img class=\"follow-avatar\" src=\"https://sns-hub-five.vercel.app/dr-iwatatsu.png\" alt=\"Dr.いわたつ\"><div class=\"follow-name\">Dr.いわたつ</div><div class=\"follow-title\">糖尿病専門医・指導医 / 内分泌専門医 / 医学博士</div><div class=\"follow-btn\">フォローする</div><div class=\"follow-actions\">💾 保存 &nbsp; 📤 シェア</div></div></div></div><script>const tl=gsap.timeline({repeat:-1});tl.to('#s1',{opacity:1,duration:.5},0).from('.hook-badge',{y:-30,opacity:0,duration:.5},0.2).from('.hook-title',{scale:.7,opacity:0,duration:.8,ease:'back.out(2)',stagger:.3},.4).from('.vs-badge',{scale:0,opacity:0,duration:.6,ease:'back.out(2)'},.8).from('.hook-sub',{y:20,opacity:0,duration:.5},1.2).to('#s1',{opacity:0,duration:.4},3.8).to('#s2',{opacity:1,duration:.4},4.2).from('.vs-side',{opacity:0,x:(i)=>i===0?-40:40,duration:.6