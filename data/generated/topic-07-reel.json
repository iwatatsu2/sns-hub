  "reelHtml": "<!DOCTYPE html><html lang=\"ja\"><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=1080,height=1920\"><title>GLP-1 多臓器保護 Reel</title><link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700;900&display=swap\" rel=\"stylesheet\"><script src=\"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js\"></script><style>*{margin:0;padding:0;box-sizing:border-box}body{width:1080px;height:1920px;overflow:hidden;font-family:'Noto Sans JP',sans-serif;background:linear-gradient(180deg,#0f172a 0%,#1e293b 50%,#312e81 100%)}.comp{width:1080px;height:1920px;position:relative;overflow:hidden}.scene{position:absolute;top:0;left:0;width:100%;height:100%;display:flex;flex-direction:column;justify-content:center;align-items:center;opacity:0;padding:60px}.hook-text{font-size:100px;font-weight:900;color:#fff;text-align:center;line-height:1.2}.hook-sub{font-size:34px;font-weight:400;color:#2dd4bf;margin-top:30px;text-align:center}.data-section{width:100%;padding:0 40px}.data-title{font-size:44px;font-weight:700;color:#2dd4bf;text-align:center;margin-bottom:50px}.data-card{background:rgba(20,184,166,0.1);border:2px solid rgba(20,184,166,0.3);border-radius:20px;padding:30px 40px;margin-bottom:24px;display:flex;align-items:center;gap:30px;opacity:0;transform:translateX(-60px)}.data-num{font-size:50px;font-weight:900;color:#14b8a6;min-width:80px}.data-text{font-size:36px;font-weight:700;color:#fff}.explain-box{background:rgba(255,255,255,0.05);border:2px solid rgba(20,184,166,0.3);border-radius:24px;padding:50px;width:90%}.explain-title{font-size:44px;font-weight:700;color:#2dd4bf;margin-bottom:30px;text-align:center}.explain-text{font-size:38px;font-weight:400;color:#fff;line-height:1.7;text-align:center}.source-badge{display:inline-block;background:rgba(20,184,166,0.2);border-radius:12px;padding:8px 20px;font-size:26px;color:#2dd4bf;margin-top:30px;text-align:center;width:100%}.summary-grid{width:90%}.summary-item{background:rgba(255,255,255,0.05);border-left:5px solid #14b8a6;border-radius:0 16px 16px 0;padding:28px 36px;margin-bottom:24px;display:flex;align-items:center;gap:20px;opacity:0;transform:translateY(30px)}.summary-check{font-size:42px;color:#2dd4bf}.summary-text{font-size:34px;font-weight:700;color:#fff}.follow-section{display:flex;flex-direction:column;align-items:center;gap:24px}.follow-avatar{width:260px;height:260px;border-radius:50%;border:4px solid #14b8a6;overflow:hidden;background:#1e293b}.follow-avatar img{width:100%;height:100%;object-fit:cover}.follow-name{font-size:56px;font-weight:900;color:#fff}.follow-title{font-size:30px;color:#94a3b8}.follow-btn{background:linear-gradient(135deg,#14b8a6,#2dd4bf);border:none;border-radius:50px;padding:20px 80px;font-size:44px;font-weight:700;color:#0f172a;margin-top:20px;cursor:pointer}.follow-actions{display:flex;gap:30px;margin-top:16px}.follow-action{font-size:28px;color:#94a3b8}</style></head><body><div class=\"comp\"><div class=\"scene\" id=\"scene1\"><div class=\"hook-text\">痩せ薬じゃない</div><div class=\"hook-sub\">GLP-1薬の本当の実力</div></div><div class=\"scene\" id=\"scene2\"><div class=\"data-section\"><div class=\"data-title\">守備範囲が広すぎる</div><div class=\"data-card\"><span class=\"data-num\">01</span><span class=\"data-text\">心血管イベント -20%</span></div><div class=\"data-card\"><span class=\"data-num\">02</span><span class=\"data-text\">腎イベント -24%</span></div><div class=\"data-card\"><span class=\"data-num\">03</span><span class=\"data-text\">NASH消退 63%</span></div><div class=\"data-card\"><span class=\"data-num\">04</span><span class=\"data-text\">無呼吸 半数が寛解</span></div></div></div><div class=\"scene\" id=\"scene3\"><div class=\"explain-box\"><div class=\"explain-title\">なぜ多臓器に効く？</div><div class=\"explain-text\">GLP-1受容体は<br>心臓・腎臓・肝臓に存在<br><br>体重減少＋直接保護の<br>「二刀流」</div><div class=\"source-badge\">NEJM 2023-2025 複数のRCT</div></div></div><div class=\"scene\" id=\"scene4\"><div class=\"data-title\" style=\"margin-bottom:40px;\">Take Home Message</div><div class=\"summary-grid\"><div class=\"summary-item\"><span class=\"summary-check\">&#10003;</span><span class=\"summary-text\">痩せ薬ではなく多臓器保護薬</span></div><div class=\"summary-item\"><span class=\"summary-check\">&#10003;</span><span class=\"summary-text\">4つの大規模RCTで実証</span></div><div class=\"summary-item\"><span class=\"summary-check\">&#10003;</span><span class=\"summary-text\">肥満患者の臓器リスクを総合評価</span></div></div></div><div class=\"scene\" id=\"scene5\"><div class=\"follow-section\"><div class=\"follow-avatar\"><img src=\"/dr-iwatatsu.png\" alt=\"Dr.いわたつ\"></div><div class=\"follow-name\">Dr.いわたつ</div><div class=\"follow-title\">糖尿病専門医 / 医学博士</div><div class=\"follow-btn\">フォローする</div><div class=\"follow-actions\"><span class=\"follow-action\">&#128278; 保存</span><span class=\"follow-action\">&#8618; シェア</span></div></div></div></div><script>const tl=gsap.timeline({repeat:-1});tl.to('#scene1',{opacity:1,duration:0.5}).from('.hook-text',{scale:0.5,opacity:0,duration:0.8,ease:'back.out(1.7)'}).from('.hook-sub',{y:30,opacity:0,duration:0.6},'<0.3').to('#scene1',{opacity:0,duration:0.4},'+=2.5').to('#scene2',{opacity:1,duration:0.5}).from('.data-title',{y:-30,opacity:0,duration:0.6}).from('.data-card',{x:-60,opacity:0,duration:0.6,stagger:0.8,ease:'power2.out'}).to('#scene2',{opacity:0,duration:0.4},'+=1.5').to('#scene3',{opacity:1,duration:0.5}).from('.explain-box',{y:50,opacity:0,duration:0.8,ease:'power2.out'}).from('.source-badge',{opacity:0,duration:0.5},'+=0.5').to('#scene3',{opacity:0,duration:0.4},'+=2').to('#scene4',{opacity:1,duration:0.5}).from('.summary-item',{y:30,opacity:0,duration:0.6,stagger:1.0,ease:'power2.out'}).to('#scene4',{opacity:0,duration:0.4},'+=2').to('#scene5',{opacity:1,duration:0.5}).from('.follow-avatar',{scale:0,duration:0.8,ease:'back.out(1.7)'}).from('.follow-name',{opacity:0,y:20,duration:0.5}).from('.follow-title',{opacity:0,y:20,duration:0.5},'<0.2').from('.follow-btn',{opacity:0,scale:0.8,duration:0.5},'<0.3').to('#scene5',{opacity:0,duration:0.4},'+=3');</script></body></html>"
