ary-item{background:rgba(255,255,255,0.05);border-left:6px solid #14b8a6;border-radius:0 16px 16px 0;padding:32px 36px;margin-bottom:24px;display:flex;align-items:center;gap:20px;opacity:0;transform:translateY(30px)}.summary-check{font-size:42px;color:#2dd4bf}.summary-text{font-size:34px;font-weight:700;color:#fff}.follow-section{display:flex;flex-direction:column;align-items:center;gap:24px}.follow-avatar{width:260px;height:260px;border-radius:50%;border:5px solid #14b8a6;overflow:hidden;opacity:0;transform:scale(0.5)}.follow-avatar img{width:100%;height:100%;object-fit:cover}.follow-name{font-size:56px;font-weight:900;color:#fff}.follow-title{font-size:30px;color:#94a3b8}.follow-btn{background:linear-gradient(135deg,#14b8a6,#2dd4bf);border:none;border-radius:50px;padding:20px 80px;font-size:44px;font-weight:700;color:#0f172a;cursor:pointer;margin-top:16px}.follow-actions{display:flex;gap:40px;margin-top:20px}.follow-action{font-size:28px;color:#94a3b8}</style></head><body><div class=\"comp\"><div class=\"scene\" id=\"scene1\"><div class=\"hook-text\">AI糖尿病管理<br>10億ドル</div><div class=\"hook-sub\">2026年、約1500億円市場へ</div></div><div class=\"scene\" id=\"scene2\"><div class=\"data-section\"><div class=\"data-title\">市場を支える3本柱+成長率</div><div class=\"data-card\" id=\"dc1\"><span class=\"data-num\">1</span><span class=\"data-text\">CGMデータのAI解析</span></div><div class=\"data-card\" id=\"dc2\"><span class=\"data-num\">2</span><span class=\"data-text\">処方支援AI（CDSS）</span></div><div class=\"data-card\" id=\"dc3\"><span class=\"data-num\">3</span><span class=\"data-text\">セルフケアAI</span></div><div class=\"data-card\" id=\"dc4\"><span class=\"data-num\">+</span><span class=\"data-text\">年成長率33%超</span></div></div></div><div class=\"scene\" id=\"scene3\"><div class=\"explain-box\"><div class=\"explain-title\">最新エビデンス</div><div class=\"explain-text\">FreeDM2試験で<br>Libre使用群は<br>HbA1c 0.6%改善<br>TIR 2.5時間延長</div><div style=\"text-align:center\"><span class=\"source-badge\">Abbott 2026</