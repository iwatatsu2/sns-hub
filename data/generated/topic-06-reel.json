x 24px;background:rgba(20,184,166,0.15);border-radius:30px;display:inline-block}.summary-grid{width:100%;padding:0 40px}.summary-item{display:flex;align-items:flex-start;gap:24px;padding:28px 36px;margin-bottom:20px;background:rgba(255,255,255,0.05);border-left:5px solid #14b8a6;border-radius:12px;opacity:0;transform:translateX(-40px)}.summary-check{font-size:42px;color:#2dd4bf;line-height:1}.summary-text{font-size:34px;font-weight:700;color:#e2e8f0;line-height:1.5}.follow-section{display:flex;flex-direction:column;align-items:center;gap:30px}.follow-avatar{width:260px;height:260px;border-radius:50%;border:5px solid #14b8a6;overflow:hidden;opacity:0;transform:scale(0.5)}.follow-avatar img{width:100%;height:100%;object-fit:cover}.follow-name{font-size:56px;font-weight:900;color:#fff}.follow-title{font-size:30px;color:#94a3b8;text-align:center;line-height:1.6}.follow-btn{font-size:44px;font-weight:900;color:#0f172a;background:linear-gradient(135deg,#14b8a6,#2dd4bf);padding:24px 80px;border-radius:60px;margin-top:20px}.follow-actions{display:flex;gap:40px;margin-top:20px}.follow-action{font-size:28px;color:#94a3b8}</style></head><body><div class=\"comp\"><div class=\"scene\" id=\"scene1\"><div class=\"hook-text\">細胞が増える</div><div class=\"hook-sub\">膵β細胞を増やす<br>分子スイッチが見つかった</div></div><div class=\"scene\" id=\"scene2\"><div class=\"data-section\"><div class=\"data-title\">最新研究データ</div><div class=\"data-card\"><span class=\"data-num\">1</span><span class=\"data-text\">2型糖尿病でβ細胞が約50%に減少</span></div><div class=\"data-card\"><span class=\"data-num\">2</span><span class=\"data-text\">ChREBPが高血糖下でβ細胞増殖を制御</span></div><div class=\"data-card\"><span class=\"data-num\">3</span><span class=\"data-text\">欠損マウスでは増殖が有意に抑制</span></div><div class=\"data-card\"><span class=\"data-num\">4</span><span class=\"data-text\">新標的遺伝子Rgs16も同定</span></div></div></div><div class=\"scene\" id=\"scene3\"><div class=\"explain-box\"><div class=\"explain-title\">なぜ画期的なのか？</div><div class=\"explain-tex