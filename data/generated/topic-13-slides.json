      "html": "<style>*{margin:0;padding:0;box-sizing:border-box}.slide{width:1280px;height:720px;font-family:'Noto Sans JP',sans-serif;position:relative;overflow:hidden}.slide-accent{background:linear-gradient(135deg,#0d4a4a,#14b8a6);color:#fff}.header{display:flex;justify-content:space-between;align-items:center;padding:24px 40px}.badge{background:rgba(255,255,255,0.2);padding:6px 18px;border-radius:20px;font-size:15px}.logo{font-size:15px;font-weight:700}.main{display:flex;align-items:center;justify-content:center;height:540px;padding:0 60px;gap:60px}.left-panel{flex:1}.right-panel{display:flex;flex-direction:column;align-items:center}h1{font-size:48px;font-weight:900;line-height:1.3;margin-bottom:20px}.subtitle{font-size:24px;opacity:0.85;line-height:1.6}.tag{display:inline-block;background:rgba(255,255,255,0.2);padding:8px 20px;border-radius:20px;font-size:16px;margin-top:16px;margin-right:8px}.avatar-circle{width:200px;height:200px;border-radius:50%;border:4px solid rgba(255,255,255,0.5);overflow:hidden;margin-bottom:16px;background:rgba(255,255,255,0.1)}.avatar-circle img{width:100%;height:100%;object-fit:cover}.author-name{font-size:24px;font-weight:700}.author-title{font-size:16px;opacity:0.8;text-align:center;line-height:1.5;margin-top:4px}.footer{position:absolute;bottom:0;width:100%;display:flex;justify-content:space-between;padding:16px 40px;font-size:13px;opacity:0.6}</style><div class=\"slide slide-accent\"><div class=\"header\"><span class=\"badge\">Slide 1 / 8</span><span class=\"logo\">Dr.いわたつ</span></div><div class=\"main\"><div class=\"left-panel\"><h1>SGLT2阻害薬の<br>正常血糖DKA</h1><div class=\"subtitle\">血糖200未満でも命に関わる<br>ケトアシドーシスの全貌</div><div><span class=\"tag\">糖尿病</span><span class=\"tag\">SGLT2阻害薬</span><span class=\"tag\">救急</span></div></div><div class=\"right-panel\"><div class=\"avatar-circle\"><img src=\"/dr-iwatatsu.png\" alt=\"Dr.いわたつ\" onerror=\"this.style.display='none'\"></div><div class=\"author-name\">Dr.いわたつ</div><div class=\"author-