0,0,0,0.06);border-top:4px solid #8b5cf6'><div style='font-size:32px;margin-bottom:10px'>🍚</div><div style='font-size:18px;font-weight:900;margin-bottom:6px'>糖質制限</div><div style='font-size:15px;color:#555'>極端な糖質制限は<br><span style='font-weight:700;color:#8b5cf6;font-size:20px'>避ける</span></div></div><div style='background:#fff;border-radius:14px;padding:24px;box-shadow:0 2px 12px rgba(0,0,0,0.06);border-top:4px solid #14b8a6'><div style='font-size:32px;margin-bottom:10px'>💉</div><div style='font-size:18px;font-weight:900;margin-bottom:6px'>治療の基本</div><div style='font-size:14px;color:#555'>SGLT2i中止<br>生食 + <span style='font-weight:700;color:#14b8a6'>5%ブドウ糖液</span></div></div><div style='background:#fff;border-radius:14px;padding:24px;box-shadow:0 2px 12px rgba(0,0,0,0.06);border-top:4px solid #0ea5e9'><div style='font-size:32px;margin-bottom:10px'>📊</div><div style='font-size:18px;font-weight:900;margin-bottom:6px'>インスリン</div><div style='font-size:14px;color:#555'>持続静注<br><span style='font-weight:700;color:#0ea5e9;font-size:18px'>0.05-0.1 U/kg/hr</span></div></div><div style='background:#fff;border-radius:14px;padding:24px;box-shadow:0 2px 12px rgba(0,0,0,0.06);border-top:4px solid #14b8a6'><div style='font-size:32px;margin-bottom:10px'>🔬</div><div style='font-size:18px;font-weight:900;margin-bottom:6px'>モニタリング</div><div style='font-size:14px;color:#555'><span style='font-weight:700;color:#14b8a6'>ケトン体・AG・pH</span><br>で改善を判定</div></div></div><div style='font-size:12px;color:#888;text-align:right;font-style:italic'>出典: 日本糖尿病学会 SGLT2阻害薬適正使用 Recommendation 2022</div></div><div class='footer'><span>© Dr.いわたつ</span><span>Dr.いわたつシリーズ</span></div></div>"
