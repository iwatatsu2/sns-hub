  "reelHtml": "<!DOCTYPE html><html lang=\"ja\"><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=1080,height=1920\"><title>Adrenal Incidentaloma Reel</title><link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700;900&display=swap\" rel=\"stylesheet\"><script src=\"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js\"></script><style>*{margin:0;padding:0;box-sizing:border-box}body{width:1080px;height:1920px;overflow:hidden;font-family:'Noto Sans JP',sans-serif}.comp{width:1080px;height:1920px;position:relative;background:linear-gradient(180deg,#0f172a 0%,#1e293b 50%,#312e81 100%)}.scene{position:absolute;top:0;left:0;width:100%;height:100%;display:flex;flex-direction:column;justify-content:center;align-items:center;opacity:0;padding:60px}.hook-text{font-size:100px;font-weight:900;color:#2dd4bf;text-align:center;line-height:1.2}.hook-sub{font-size:34px;font-weight:400;color:#e2e8f0;text-align:center;margin-top:40px;line-height:1.6}.data-section{width:100%;padding:0 40px}.data-title{font-size:44px;font-weight:700;color:#fff;text-align:center;margin-bottom:50px}.data-card{display:flex;align-items:center;background:rgba(20,184,166,0.1);border:2px solid rgba(20,184,166,0.3);border-radius:20px;padding:30px 40px;margin-bottom:24px;opacity:0}.data-num{font-size:50px;font-weight:900;color:#14b8a6;margin-right:30px;min-width:60px}.data-text{font-size:36px;font-weight:700;color:#e2e8f0}.explain-box{background:rgba(255,255,255,0.05);border:2px solid rgba(20,184,166,0.3);border-radius:24px;padding:50px;margin:0 40px;width:calc(100% - 80px)}.explain-title{font-size:44px;font-weight:700;color:#2dd4bf;margin-bottom:30px;text-align:center}.explain-text{font-size:38px;font-weight:400;color:#e2e8f0;line-height:1.7}.source-badge{display:inline-block;background:rgba(20,184,166,0.2);border-radius:12px;padding:12px 24px;margin-top:30px;font-size:26px;color:#2dd4bf}.summary-grid{width:100%;padding:0 40px}.summary-item{display:flex;align-items:flex-start;background:rgba(255,255,255,0.05);border-left:6px solid #14b8a6;border-radius:0 16px 16px 0;padding:30px 36px;margin-bottom:28px;opacity:0}.summary-check{font-size:42px;color:#2dd4bf;margin-right:24px;min-width:50px}.summary-text{font-size:34px;font-weight:700;color:#e2e8f0;line-height:1.5}.follow-section{display:flex;flex-direction:column;align-items:center}.follow-avatar{width:260px;height:260px;border-radius:50%;border:6px solid #14b8a6;overflow:hidden;margin-bottom:30px;background:#1e293b}.follow-avatar img{width:100%;height:100%;object-fit:cover}.follow-name{font-size:56px;font-weight:900;color:#fff;margin-bottom:10px}.follow-title{font-size:30px;color:#94a3b8;margin-bottom:40px;text-align:center;line-height:1.5}.follow-btn{background:linear-gradient(135deg,#14b8a6,#2dd4bf);color:#0f172a;font-size:44px;font-weight:700;padding:24px 80px;border-radius:60px;cursor:pointer}.follow-actions{display:flex;gap:40px;margin-top:30px}.follow-action{font-size:28px;color:#94a3b8}</style></head><body><div class=\"comp\"><div class=\"scene\" id=\"scene1\"><div class=\"hook-text\">副腎に影がある</div><div class=\"hook-sub\">CTで偶然見つかった副腎腫瘤<br>放置していいですか？</div></div><div class=\"scene\" id=\"scene2\"><div class=\"data-section\"><div class=\"data-title\">副腎偶発腫の真実</div><div class=\"data-card\"><span class=\"data-num\">01</span><span class=\"data-text\">CT検査の4%で偶然発見</span></div><div class=\"data-card\"><span class=\"data-num\">02</span><span class=\"data-text\">褐色細胞腫の35%は無症候性</span></div><div class=\"data-card\"><span class=\"data-num\">03</span><span class=\"data-text\">全例にDST+メタネフリン必須</span></div><div class=\"data-card\"><span class=\"data-num\">04</span><span class=\"data-text\">CT値10HU以下なら良性腺腫</span></div></div></div><div class=\"scene\" id=\"scene3\"><div class=\"explain-box\"><div class=\"explain-title\">見逃すと致命的</div><div class=\"explain-text\">褐色細胞腫を見逃すと<br>高血圧クリーゼで命に関わる<br>無症状でも全例メタネフリン測定</div><div class=\"source-badge\">出典：ESE/ENSAT Guideline 2023</div></div></div><div class=\"scene\" id=\"scene4\"><div class=\"data-title\" style=\"color:#fff;font-size:44px;font-weight:700;margin-bottom:50px;text-align:center\">精査フローチャート</div><div class=\"summary-grid\"><div class=\"summary-item\"><span class=\"summary-check\">&#10003;</span><span class=\"summary-text\">1mg DSTで<br>コルチゾール評価</span></div><div class=\"summary-item\"><span class=\"summary-check\">&#10003;</span><span class=\"summary-text\">メタネフリンで<br>褐色細胞腫を除外</span></div><div class=\"summary-item\"><span class=\"summary-check\">&#10003;</span><span class=\"summary-text\">高血圧あれば<br>ARRを追加</span></div></div></div><div class=\"scene\" id=\"scene5\"><div class=\"follow-section\"><div class=\"follow-avatar\"><img src=\"/dr-iwatatsu.png\" alt=\"Dr.いわたつ\" onerror=\"this.style.display='none'\"></div><div class=\"follow-name\">Dr.いわたつ</div><div class=\"follow-title\">糖尿病専門医・指導医<br>内分泌専門医 / 医学博士</div><div class=\"follow-btn\">フォローする</div><div class=\"follow-actions\"><span class=\"follow-action\">&#9733; 保存</span><span class=\"follow-action\">&#8634; シェア</span></div></div></div></div><script>const tl=gsap.timeline({repeat:-1});tl.to('#scene1',{opacity:1,duration:0.5}).from('.hook-text',{scale:0.5,opacity:0,duration:0.8,ease:'back.out(1.7)'}).from('.hook-sub',{y:40,opacity:0,duration:0.6},'+=0.3').to('#scene1',{opacity:0,duration:0.4},'+=2.5');tl.to('#scene2',{opacity:1,duration:0.5}).from('.data-title',{y:-30,opacity:0,duration:0.5}).from('.data-card',{x:-80,opacity:0,duration:0.6,stagger:0.8,ease:'power2.out'}).to('#scene2',{opacity:0,duration:0.4},'+=1.5');tl.to('#scene3',{opacity:1,duration:0.5}).from('.explain-box',{y:60,opacity:0,duration:0.8,ease:'power2.out'}).from('.source-badge',{opacity:0,duration:0.5},'+=0.5').to('#scene3',{opacity:0,duration:0.4},'+=2.5');tl.to('#scene4',{opacity:1,duration:0.5}).from('.summary-item',{x:-60,opacity:0,duration:0.6,stagger:1.0,ease:'power2.out'}).to('#scene4',{opacity:0,duration:0.4},'+=2');tl.to('#scene5',{opacity:1,duration:0.5}).from('.follow-avatar',{scale:0,duration:0.8,ease:'back.out(1.7)'}).from('.follow-name',{y:20,opacity:0,duration:0.4}).from('.follow-title',{y:20,opacity:0,duration:0.4}).from('.follow-btn',{scale:0.8,opacity:0,duration:0.5,ease:'back.out(1.7)'}).from('.follow-actions',{opacity:0,duration:0.4}).to('#scene5',{opacity:0,duration:0.4},'+=2.5');</script></body></html>"
}
