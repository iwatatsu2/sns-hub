  {
    "num": 6,
    "title": "Take Home Message",
    "style": "accent",
    "content": "3つの持ち帰りポイント",
    "html": "<style>*{margin:0;padding:0;box-sizing:border-box}.slide{width:1280px;height:720px;font-family:'Noto Sans JP',sans-serif;display:flex;flex-direction:column;position:relative;overflow:hidden}.slide-accent{background:linear-gradient(135deg,#0d4a4a,#14b8a6);color:#fff}.header{display:flex;justify-content:space-between;align-items:center;padding:20px 40px}.badge{background:rgba(255,255,255,0.2);color:#fff;font-size:15px;padding:6px 16px;border-radius:20px}.logo{font-size:15px;color:rgba(255,255,255,0.8)}.main{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:0 60px;gap:24px}.section-title{font-size:36px;font-weight:900;margin-bottom:20px;text-align:center}.thm-card{background:rgba(255,255,255,0.12);border-radius:20px;padding:28px 40px;width:90%;display:flex;align-items:center;gap:24px;backdrop-filter:blur(10px)}.thm-num{font-size:36px;font-weight:900;color:#2dd4bf;min-width:50px}.thm-text{font-size:26px;font-weight:700;line-height:1.5}.footer{display:flex;justify-content:space-between;padding:16px 40px;font-size:13px;color:rgba(255,255,255,0.5)}</style><div class=\"slide slide-accent\"><div class=\"header\"><span class=\"badge\">SLIDE 06 / 08</span><span class=\"logo\">Dr.いわたつ</span></div><div class=\"main\"><div class=\"section-title\">Take Home Message</div><div class=\"thm-card\"><span class=\"thm-num\">1</span><span class=\"thm-text\">GLP-1RAは「血糖降下薬」から「臓器保護薬」へ<br>心血管26%減・腎24%減のエビデンスを臨床に活かす</span></div><div class=\"thm-card\"><span class=\"thm-num\">2</span><span class=\"thm-text\">副腎偶発腫は「小さいから安心」ではない<br>DST・メタネフリン・ARRの3検査でホルモン評価</span></div><div class=\"thm-card\"><span class=\"thm-num\">3</span><span class=\"thm-text\">AI内分泌診断は「任せる」のではなく「使いこなす」<br>甲状腺エコーAI AUC 0.82は臨床支援に有用</span></div></div><div class=\"footer\"><span>&copy; Dr.いわたつ</span><span>Dr.いわたつシリーズ</span></div></div>"
  },
