  "reelHtml": "<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=1080\">\n<title>SGLT2阻害薬と正常血糖DKA</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700;900&display=swap\" rel=\"stylesheet\">\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js\"></script>\n<style>\n*{margin:0;padding:0;box-sizing:border-box}\nbody{overflow:hidden;background:#0f172a}\n.comp{position:relative;width:1080px;height:1920px;background:linear-gradient(180deg,#0f172a 0%,#1e293b 50%,#312e81 100%);font-family:'Noto Sans JP',sans-serif;overflow:hidden;color:#fff}\n.scene{position:absolute;top:0;left:0;width:100%;height:100%;display:flex;flex-direction:column;justify-content:center;align-items:center;opacity:0;padding:60px}\n.watermark-wrap{position:absolute;right:20px;bottom:120px;z-index:10;pointer-events:none;text-align:center;display:flex;flex-direction:column;align-items:center}.watermark-wrap img{height:400px;width:auto;object-fit:contain;filter:drop-shadow(0 4px 16px rgba(0,0,0,.4))}.watermark-name{font-size:24px;font-weight:700;color:#fff;margin-top:8px;text-shadow:0 2px 8px rgba(0,0,0,.5)}\n.hook-text{font-size:100px;font-weight:900;text-align:center;line-height:1.3;background:linear-gradient(135deg,#2dd4bf,#14b8a6);-webkit-background-clip:text;-webkit-text-fill-color:transparent}\n.hook-sub{font-size:34px;font-weight:400;text-align:center;color:rgba(255,255,255,.8);margin-top:40px;line-height:1.6}\n.data-section{width:100%;padding:0 40px}\n.data-title{font-size:44px;font-weight:700;text-align:center;margin-bottom:50px;color:#2dd4bf}\n.data-card{display:flex;align-items:center;background:rgba(255,255,255,.08);border-radius:20px;padding:28px 36px;margin-bottom:24px;border-left:6px solid #14b8a6;opacity:0;transform:translateX(-60px)}\n.data-num{font-size:50px;font-weight:900;color:#2dd4bf;margin-right:30px;min-width:60px;text-align:center}\n.data-text{font-size:36px;font-weight:700;line-height:1.4}\n.explain-box{background:rgba(255,255,255,.07);border-radius:28px;padding:60px 50px;margin:0 40px;border:1px solid rgba(45,212,191,.3)}\n.explain-title{font-size:44px;font-weight:900;color:#2dd4bf;margin-bottom:30px;text-align:center}\n.explain-text{font-size:38px;font-weight:400;line-height:1.7;color:rgba(255,255,255,.9)}\n.source-badge{display:inline-block;background:rgba(20,184,166,.2);border:1px solid rgba(20,184,166,.4);border-radius:12px;padding:8px 20px;font-size:26px;color:#2dd4bf;margin-top:30px}\n.summary-title{font-size:44px;font-weight:900;color:#2dd4bf;margin-bottom:50px;text-align:center}\n.summary-grid{width:100%;padding:0 40px}\n.summary-item{display:flex;align-items:center;background:rgba(255,255,255,.06);border-left:6px solid #14b8a6;border-radius:16px;padding:32px 36px;margin-bottom:28px;opacity:0;transform:translateX(-40px)}\n.summary-check{font-size:42px;margin-right:24px;color:#2dd4bf}\n.summary-text{font-size:34px;font-weight:700;line-height:1.5}\n.follow-section{display:flex;flex-direction:column;align-items:center}\n.follow-avatar{width:260px;height:300px;object-fit:contain;margin-bottom:20px;filter:drop-shadow(0 4px 20px rgba(20,184,166,.4))}\n.follow-name{font-size:56px;font-weight:900;margin-bottom:10px}\n.follow-title{font-size:30px;color:rgba(255,255,255,.7);margin-bottom:40px;text-align:center}\n.follow-btn{background:linear-gradient(135deg,#14b8a6,#0d9488);border:none;color:#fff;font-size:44px;font-weight:700;padding:24px 80px;border-radius:60px;font-family:'Noto Sans JP',sans-serif;cursor:pointer}\n.follow-actions{display:flex;gap:40px;margin-top:36px;font-size:30px;color:rgba(255,255,255,.6)}\n</style>\n</head>\n<body>\n<div class=\"comp\">\n  <div class=\"watermark-wrap\" id=\"watermark\"><img src=\"https://sns-hub-five.vercel.app/dr-iwatatsu.png\" alt=\"Dr.いわたつ\"><div class=\"watermark-name\">Dr.いわたつ</div></div>\n  <div class=\"scene\" id=\"scene1\">\n    <div class=\"hook-text\">血糖正常でも危険</div>\n    <div class=\"hook-sub\">その薬、血糖が普通でも<br>体が酸性に傾くことがあります</div>\n  </div>\n  <div class=\"scene\" id=\"scene2\">\n    <div class=\"data-section\">\n      <div class=\"data-title\">知っておきたい4つの事実</div>\n      <div class=\"data-card\"><span class=\"data-num\">1</span><span class=\"data-text\">SGLT2阻害薬で<br>DKAリスク 2.3倍</span></div>\n      <div class=\"data-card\"><span class=\"data-num\">2</span><span class=\"data-text\">吐き気・嘔吐が<br>57〜76%に出現</span></div>\n      <div class=\"data-card\"><span class=\"data-num\">3</span><span class=\"data-text\">血糖値が正常だから<br>見逃されやすい</span></div>\n      <div class=\"data-card\"><span class=\"data-num\">4</span><span class=\"data-text\">体調不良・手術前・<br>脱水が引き金に</span></div>\n    </div>\n  </div>\n  <div class=\"scene\" id=\"scene3\">\n    <div class=\"explain-box\">\n      <div class=\"explain-title\">なぜ起こる？</div>\n      <div class=\"explain-text\">SGLT2阻害薬は心臓や腎臓も守る<br>とても優秀なお薬です。<br><br>でも体調が悪い日はお休みが鉄則。<br><br>血糖値だけでは判断できない<br>「隠れた落とし穴」があるんです。</div>\n      <div class=\"source-badge\">Lee et al. 2025</div>\n    </div>\n  </div>\n  <div class=\"scene\" id=\"scene4\">\n    <div class=\"summary-title\">覚えておきたい3つの対策</div>\n    <div class=\"summary-grid\">\n      <div class=\"summary-item\"><span class=\"summary-check\">✓</span><span class=\"summary-text\">体調が悪い日は<br>いったん休薬する</span></div>\n      <div class=\"summary-item\"><span class=\"summary-check\">✓</span><span class=\"summary-text\">手術の3日前から<br>休薬する</span></div>\n      <div class=\"summary-item\"><span class=\"summary-check\">✓</span><span class=\"summary-text\">極端な糖質制限は<br>避ける</span></div>\n    </div>\n  </div>\n  <div class=\"scene\" id=\"scene5\">\n    <div class=\"follow-section\">\n      <img class=\"follow-avatar\" src=\"https://sns-hub-five.vercel.app/dr-iwatatsu.png\" alt=\"Dr.いわたつ\">\n      <div class=\"follow-name\">Dr.いわたつ</div>\n      <div class=\"follow-title\">糖尿病・肥満症の専門医<br>「知って得する」医療情報を発信中</div>\n      <button class=\"follow-btn\">フォローする</button>\n      <div class=\"follow-actions\"><span>保存</span><span>シェア</span></div>\n    </div>\n  </div>\n</div>\n<script>\nconst wm = document.getElementById('watermark');\nconst tl = gsap.timeline({repeat:-1});\ntl.to('#scene1',{opacity:1,duration:.4})\n  .from('.hook-text',{scale:.6,opacity:0,duration:.8,ease:'back.out(1.7)'},'-=0.2')\n  .from('.hook-sub',{y:30,opacity:0,duration:.6},'+=0.2')\n  .to('#scene1',{opacity:0,duration:.4},'+=1.6');\ntl.to('#scene2',{opacity:1,duration:.4})\n  .from('.data-title',{y:-20,opacity:0,duration:.5})\n  .to('.data-card',{opacity:1,x:0,duration:.6,stagger:.8,ease:'power2.out'})\n  .to('#scene2',{opacity:0,duration:.4},'+=0.3');\ntl.to('#scene3',{opacity:1,duration:.4})\n  .from('.explain-box',{y:40,opacity:0,duration:.7,ease:'power2.out'})\n  .from('.source-badge',{opacity:0,duration:.4},'+=0.5')\n  .to('#scene3',{opacity:0,duration:.4},'+=1.5');\ntl.to('#scene4',{opacity:1,duration:.4})\n  .from('.summary-title',{y:-20,opacity:0,duration:.5})\n  .to('.summary-item',{opacity:1,x:0,duration:.6,stagger:1.0,ease:'power2.out'})\n  .to('#scene4',{opacity:0,duration:.4},'+=0.5');\ntl.to('#scene4',{opacity:0,duration:.4,onComplete:function(){wm.style.display='none';}})\n  .to('#scene5',{opacity:1,duration:.4})\n  .from('.follow-avatar',{scale:0,duration:.7,ease:'back.out(1.7)'})\n  .from('.follow-name',{opacity:0,y:20,duration:.4})\n  .from('.follow-title',{opacity:0,duration:.4})\n  .from('.follow-btn',{scale:.8,opacity:0,duration:.4,ease:'back.out(1.7)'})\n  .from('.follow-actions',{opacity:0,duration:.3})\n  .to('#scene5',{opacity:0,duration:.4,onComplete:function(){wm.style.display='block';}},'+=1.2');\n</script>\n</body>\n</html>"
}