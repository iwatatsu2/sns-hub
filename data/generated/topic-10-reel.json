:24px;background:rgba(255,255,255,0.05);border-left:4px solid #14b8a6;border-radius:0 16px 16px 0;padding:30px 36px;margin-bottom:24px;opacity:0;transform:translateX(-40px)}.summary-check{font-size:42px;color:#2dd4bf;min-width:50px}.summary-text{font-size:34px;font-weight:700;color:#fff;line-height:1.4}.follow-section{display:flex;flex-direction:column;align-items:center;gap:30px}.follow-avatar{width:260px;height:260px;border-radius:50%;border:4px solid #14b8a6;overflow:hidden;opacity:0;transform:scale(0.5)}.follow-avatar img{width:100%;height:100%;object-fit:cover}.follow-name{font-size:56px;font-weight:900;color:#fff;opacity:0}.follow-title{font-size:30px;color:#94a3b8;opacity:0}.follow-btn{background:linear-gradient(135deg,#14b8a6,#0d9488);color:#fff;font-size:44px;font-weight:700;padding:24px 80px;border-radius:60px;opacity:0;transform:translateY(20px)}.follow-actions{display:flex;gap:30px;margin-top:10px;opacity:0}.follow-action{color:#94a3b8;font-size:28px;font-weight:700}</style></head><body><div class=\"comp\"><div class=\"scene\" id=\"scene1\"><div class=\"hook-text\">処方が変わる</div><div class=\"hook-sub\">標準診療マニュアル2026改訂</div></div><div class=\"scene\" id=\"scene2\"><div class=\"data-section\"><div class=\"data-title\">4つの改訂ポイント</div><div class=\"data-card\"><span class=\"data-num\">01</span><span class=\"data-text\">GLP-1薬が格上げ</span></div><div class=\"data-card\"><span class=\"data-num\">02</span><span class=\"data-text\">心血管既往+肥満で優先</span></div><div class=\"data-card\"><span class=\"data-num\">03</span><span class=\"data-text\">DPP-4との併用は禁忌</span></div><div class=\"data-card\"><span class=\"data-num\">04</span><span class=\"data-text\">合併症で薬を選ぶ時代</span></div></div></div><div class=\"scene\" id=\"scene3\"><div class=\"explain-box\"><div class=\"explain-title\">何が変わった?</div><div class=\"explain-text\">経口GLP-1 RAに「心血管疾患の既往・肥満があれば積極的に投与開始してよい」と明記</div><div class=\"source-badge\">糖尿病標準診療マニュアル2026</div></div></div><div class=\"scene\" id=\"scene4\"><div class=\"s