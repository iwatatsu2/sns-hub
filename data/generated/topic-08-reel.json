border-radius:0 16px 16px 0;padding:28px 32px;margin-bottom:24px;opacity:0}.summary-check{font-size:42px;color:#2dd4bf;min-width:50px}.summary-text{font-size:34px;font-weight:700;color:#fff;line-height:1.4}.follow-section{display:flex;flex-direction:column;align-items:center;gap:24px}.follow-avatar{width:260px;height:260px;border-radius:50%;border:4px solid #14b8a6;overflow:hidden;background:#1e293b}.follow-avatar img{width:100%;height:100%;object-fit:cover}.follow-name{font-size:56px;font-weight:900;color:#fff}.follow-title{font-size:30px;color:#94a3b8;text-align:center}.follow-btn{margin-top:16px;padding:20px 80px;background:linear-gradient(135deg,#14b8a6,#2dd4bf);border-radius:60px;font-size:44px;font-weight:900;color:#0f172a}.follow-actions{display:flex;gap:40px;margin-top:20px}.follow-action{font-size:28px;color:#5eead4;font-weight:700}</style></head><body><div class=\"comp\"><div class=\"scene\" id=\"scene1\"><div class=\"hook-text\">GLP-1の次</div><div class=\"hook-sub\">次世代肥満症薬が3つ来た</div></div><div class=\"scene\" id=\"scene2\"><div class=\"data-section\"><div class=\"data-title\">注目の3剤</div><div class=\"data-card\"><span class=\"data-num\">01</span><span class=\"data-text\">アミクレチン：-22%減量</span></div><div class=\"data-card\"><span class=\"data-num\">02</span><span class=\"data-text\">survodutide：肝脂肪も改善</span></div><div class=\"data-card\"><span class=\"data-num\">03</span><span class=\"data-text\">orforglipron：飲み薬</span></div><div class=\"data-card\"><span class=\"data-num\">04</span><span class=\"data-text\">全てPhase 3段階</span></div></div></div><div class=\"scene\" id=\"scene3\"><div class=\"explain-box\"><div class=\"explain-title\">最大の衝撃</div><div class=\"explain-text\">アミクレチンは<br>36週で-22%減量<br>プラトー未到達＝まだ減る</div><div class=\"source-badge\">Lancet 2025</div></div></div><div class=\"scene\" id=\"scene4\"><div class=\"data-title\" style=\"color:#2dd4bf;font-size:44px;font-weight:900;margin-bottom:40px\">まとめ</div><div class=\"summary-grid\"><div class=\"summary-item\"><span class=\"summary-check\">&#10003;</span><span class=\"summary-text\">GLP-1+アミリンで最強減量</span></div><div class=\"summary-item\"><span class=\"summary-check\">&#10003;</span><span class=\"summary-text\">グルカゴン併用で肝臓も守る</span></div><div class=\"summary-item\"><span class=\"summary-check\">&#10003;</span><span class=\"summary-text\">経口薬で注射バリア解消</span></div></div></div><div class=\"scene\" id=\"scene5\"><div class=\"follow-section\"><div class=\"follow-avatar\"><img src=\"/dr-iwatatsu.png\" alt=\"Dr.いわたつ\"></div><div class=\"follow-name\">Dr.いわたつ</div><div class=\"follow-title\">糖尿病・肥満症専門医<br>内分泌専門医 / 医学博士</div><div class=\"follow-btn\">フォローする</div><div class=\"follow-actions\"><span class=\"follow-action\">保存</span><span class=\"follow-action\">シェア</span></div></div></div></div><script>const tl=gsap.timeline({repeat:-1});tl.to('#scene1',{opacity:1,duration:0.5}).from('.hook-text',{scale:0.5,opacity:0,duration:0.8,ease:'back.out(1.7)'}).from('.hook-sub',{y:30,opacity:0,duration:0.6},'-=0.3').to('#scene1',{opacity:0,duration:0.4},'+=2.5').to('#scene2',{opacity:1,duration:0.5}).from('.data-title',{y:-20,opacity:0,duration:0.5}).from('.data-card',{x:-80,opacity:0,duration:0.6,stagger:0.8,ease:'power2.out'}).to('#scene2',{opacity:0,duration:0.4},'+=1.5').to('#scene3',{opacity:1,duration:0.5}).from('.explain-box',{y:40,opacity:0,duration:0.7,ease:'power2.out'}).from('.source-badge',{scale:0,duration:0.4},'-=0.2').to('#scene3',{opacity:0,duration:0.4},'+=2.5').to('#scene4',{opacity:1,duration:0.5}).from('.summary-item',{x:-60,opacity:0,duration:0.6,stagger:1.0,ease:'power2.out'}).to('#scene4',{opacity:0,duration:0.4},'+=2').to('#scene5',{opacity:1,duration:0.5}).from('.follow-avatar',{scale:0,duration:0.6,ease:'back.out(1.7)'}).from('.follow-name',{y:20,opacity:0,duration:0.4}).from('.follow-title',{y:20,opacity:0,duration:0.4},'-=0.2').from('.follow-btn',{scale:0.5,opacity:0,duration:0.5,ease:'back.out(1.7)'}).from('.follow-actions',{opacity:0,duration:0.4}).to('#scene5',{opacity:0,duration:0.4},'+=2.5');</script></body></html>"
